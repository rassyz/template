# General
TZ=Asia/Jakarta

# Laravel app values used only when src/.env does not exist yet.
APP_NAME=Winnicode
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://winnicode.test
ASSET_URL=https://winnicode.test
DEBUGBAR_ENABLED=false

# Leave APP_KEY empty.
# docker-entrypoint.sh will run: php artisan key:generate --force
APP_KEY=

# Laravel database connection
DB_CONNECTION=mariadb
DB_HOST=winnicode_db
DB_PORT=3306
DB_DATABASE=winnicode
DB_USERNAME=root
DB_PASSWORD=change_me_laravel_db_password

# MariaDB initialization
MYSQL_DATABASE=winnicode
MYSQL_USER=rassyz
MYSQL_PASSWORD=change_me_laravel_db_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# Development tools
XDEBUG=false
PHP_IDE_CONFIG=serverName=winnicode
REMOTE_HOST=host.docker.internal